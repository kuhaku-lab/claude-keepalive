{
  "name": "claude-keepalive",
  "version": "0.0.1",
  "description": "Drop-in replacement for `claude -p` that eliminates cold-start by reusing warm claude processes.",
  "license": "Apache-2.0",
  "author": "kuhaku",
  "homepage": "https://github.com/kuhaku/claude-keepalive#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuhaku/claude-keepalive.git"
  },
  "bugs": {
    "url": "https://github.com/kuhaku/claude-keepalive/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "keepalive",
    "warm-pool",
    "stop-hook",
    "task-runner"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README-JP.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check --write",
    "smoke:warm": "pnpm build && node scripts/warm-smoke.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.10.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
